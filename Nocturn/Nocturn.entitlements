<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Nocturn entitlement rationale:
	     - app-sandbox=false: required for low-level CoreAudio control paths.
	     - device.audio-input=true: microphone permission/audio input access used by tap flows.
	     - coreaudio.tap-enabled=true: enables CATapDescription process taps on supported macOS. -->
	<key>com.apple.developer.coreaudio.tap-enabled</key>
	<true/>
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
